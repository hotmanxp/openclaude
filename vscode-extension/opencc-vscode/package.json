{
  "name": "opencc-vscode",
  "displayName": "OpenCC",
  "description": "Practical VS Code companion for OpenCC with project-aware launch behavior and a real Control Center.",
  "version": "0.1.1",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:opencc.start",
    "onCommand:opencc.startInWorkspaceRoot",
    "onCommand:opencc.openDocs",
    "onCommand:opencc.openSetupDocs",
    "onCommand:opencc.openWorkspaceProfile",
    "onCommand:opencc.openControlCenter",
    "onView:opencc.controlCenter"
  ],
  "main": "./src/extension.js",
  "files": [
    "README.md",
    "media/**",
    "src/extension.js",
    "src/presentation.js",
    "src/state.js",
    "themes/**"
  ],
  "contributes": {
    "commands": [
      {
        "command": "opencc.start",
        "title": "OpenCC: Launch in Terminal",
        "category": "OpenCC"
      },
      {
        "command": "opencc.startInWorkspaceRoot",
        "title": "OpenCC: Launch in Workspace Root",
        "category": "OpenCC"
      },
      {
        "command": "opencc.openDocs",
        "title": "OpenCC: Open Repository",
        "category": "OpenCC"
      },
      {
        "command": "opencc.openSetupDocs",
        "title": "OpenCC: Open Setup Guide",
        "category": "OpenCC"
      },
      {
        "command": "opencc.openWorkspaceProfile",
        "title": "OpenCC: Open Workspace Profile",
        "category": "OpenCC"
      },
      {
        "command": "opencc.openControlCenter",
        "title": "OpenCC: Open Control Center",
        "category": "OpenCC"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencc",
          "title": "OpenCC",
          "icon": "media/opencc.svg"
        }
      ]
    },
    "views": {
      "opencc": [
        {
          "id": "opencc.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "OpenCC",
      "properties": {
        "opencc.launchCommand": {
          "type": "string",
          "default": "opencc",
          "description": "Command run in the integrated terminal when launching OpenCC."
        },
        "opencc.terminalName": {
          "type": "string",
          "default": "OpenCC",
          "description": "Integrated terminal tab name for OpenCC sessions."
        },
        "opencc.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally set CLAUDE_CODE_USE_OPENAI=1 in launched OpenCC terminals."
        }
      }
    },
    "themes": [
      {
        "label": "OpenCC Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/OpenCC-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "test": "node --test ./src/*.test.js",
    "lint": "node -e \"for (const file of require('node:fs').readdirSync('./src')) { if (file.endsWith('.js')) { require('node:child_process').execFileSync(process.execPath, ['--check', require('node:path').join('src', file)], { stdio: 'inherit' }); } }\"",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "opencc",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Gitlawb/opencc"
  },
  "license": "MIT"
}
